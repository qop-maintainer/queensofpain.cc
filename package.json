{
  "name": "queensofpain.cc",
  "description": "Community site for the Queens of Pain cycling community.",
  "author": {
    "name": "Queens of Pain"
  },
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --ignore-path .gitignore .prettierignore --ignore-unknown --write \"**/*.{js,mjs,json,ts,tsx,md,mdx,yml,yaml,astro,feature}\"",
    "browsers": "turbo run browsers",
    "e2e": "turbo run e2e",
    "ci": "turbo run ci"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead"
    ],
    "development": [
      "last 2 Chrome versions",
      "last 1 Firefox versions",
      "last 1 Safari versions"
    ]
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-gherkin": "3.1.3",
    "turbo": "2.9.1",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
