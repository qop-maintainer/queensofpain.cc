{
  "name": "queensofpain.cc",
  "description": "Community site for the Queens of Pain cycling community.",
  "author": {
    "name": "Queens of Pain"
  },
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --ignore-path .gitignore --ignore-unknown --write \"**/*.{js,mjs,json,ts,tsx,md,mdx,yml,astro,feature}\"",
    "browsers": "turbo run browsers",
    "e2e": "turbo run e2e",
    "ci": "turbo run ci"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead"
    ],
    "development": [
      "last 2 Chrome versions",
      "last 1 Firefox versions",
      "last 1 Safari versions"
    ]
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-gherkin": "3.1.3",
    "turbo": "2.8.14",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "sharp@<0.32.6": ">=0.32.6",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "nanoid@<3.3.8": ">=3.3.8",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "svgo@=4.0.0": ">=4.0.1"
    }
  }
}
