const data = [
  {
    Date: "2026-03-04",
    "Ride Name": "QoP #255: The Swoopy Bit",
    "Outliers URL": "https://outliers.microcosm.app/events/11653/",
    "Starting At": "Meadows Pavilion",
    "Led By": "Eve",
  },
];

type rideType = {
  Date: string;
  "Ride Name": string;
  "Outliers URL": string;
  "Starting At": string;
  "Led By": string;
};
---

<ul>
  {
    data
      .filter((ride: rideType) => new Date(ride["Date"]) >= new Date())
      .sort(
        (a: rideType, b: rideType) =>
          new Date(a["Date"]).getTime() - new Date(b["Date"]).getTime(),
      )
      .map((ride: rideType) => (
        <li>
          <a
            class="link"
            href={ride["Outliers URL"]}
            target="_blank"
            rel="noopener noreferrer"
          >
            {ride["Date"]} - <b>{ride["Ride Name"]}</b>, led by {ride["Led By"]}{" "}
            and starting at {ride["Starting At"]}
          </a>
        </li>
      ))
  }
</ul>
